# Dependencies — installed by Netlify's build (npm install) from package.json,
# never committed themselves.
node_modules/

# Netlify CLI local state (only appears if you ever run `netlify dev` locally).
.netlify/

# Secrets — never commit real keys. STRIPE_SECRET_KEY and STRIPE_WEBHOOK_SECRET
# belong in Netlify's Environment variables, not in a file in this repo.
.env
.env.*

# OS/editor cruft
.DS_Store
Thumbs.db
